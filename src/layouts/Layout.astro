---
// src/layouts/Layout.astro
import logoMadecem from '../assets/logo-madecem.svg';

interface Props {
	title: string;
	description?: string;
	theme?: 'carniceria' | 'taller' | 'peluqueria' | 'restaurante' | 'empresa';
}

const { 
    title, 
    description = "Ingeniería de IA para negocios reales. Recupera tu tiempo y automatiza tareas repetitivas.", 
    theme 
} = Astro.props;

const socialImageURL = new URL('/social.png', Astro.site || Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
        <title>{title}</title>
		<meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:site_name" content="MADECEM S.L." />
        <meta property="og:locale" content="es_ES" />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
	</head>
	<body class="bg-[#020617] text-white font-sans selection:bg-blue-500/30 flex flex-col min-h-screen">
		
		<nav class="fixed top-0 w-full z-[100] bg-[#020617]/90 backdrop-blur-xl border-b border-white/5">
			<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
				
				<a href="/" class="flex items-center gap-3 group" aria-label="Ir al inicio">
					<div class="h-10 flex items-center justify-center">
                        <img 
                            src={logoMadecem.src} 
                            width="150"
                            height="40"
                            alt="Logotipo MADECEM" 
                            class="h-full w-auto object-contain group-hover:scale-105 transition-transform"
                        />
					</div>
					<span class="text-2xl font-black tracking-tighter text-white">MADECEM</span>
				</a>
				
				<div class="hidden md:flex gap-8 items-center">
					<a href="/" class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-colors">Inicio</a>
					<a href="/empresa" class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-colors">Empresa</a>
					<a href="/servicios" class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-colors">Servicios</a>
					<a href="/como-trabajamos" class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-colors">Cómo trabajamos</a>
					<a href="/software-e-innovacion" class="text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-white transition-colors">Software e innovación</a>
					<a href="/#contacto" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-full text-sm font-bold shadow-lg shadow-blue-600/20 transition-all hover:scale-105">
						Solicitar diagnóstico
					</a>
				</div>

				<button id="mobile-menu-button" class="md:hidden p-2 text-slate-300 hover:text-white focus:outline-none" aria-label="Abrir menú de navegación">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
					</svg>
				</button>
			</div>

			<div id="mobile-menu" class="hidden md:hidden bg-[#020617] border-b border-white/5 px-6 py-8 space-y-6 shadow-2xl">
				<a href="/" class="block text-xl font-bold uppercase tracking-widest text-white mobile-link hover:text-blue-500 transition-colors">Inicio</a>
				<a href="/empresa" class="block text-xl font-bold uppercase tracking-widest text-white mobile-link hover:text-blue-500 transition-colors">Empresa</a>
				<a href="/servicios" class="block text-xl font-bold uppercase tracking-widest text-white mobile-link hover:text-blue-500 transition-colors">Servicios</a>
				<a href="/como-trabajamos" class="block text-xl font-bold uppercase tracking-widest text-white mobile-link hover:text-blue-500 transition-colors">Cómo trabajamos</a>
				<a href="/software-e-innovacion" class="block text-xl font-bold uppercase tracking-widest text-white mobile-link hover:text-blue-500 transition-colors">Software e innovación</a>
				<a href="/#contacto" class="block w-full text-center bg-blue-600 text-white py-4 rounded-2xl font-black mobile-link active:scale-95 transition-transform">
					Solicitar diagnóstico
				</a>
			</div>
		</nav>

		<main class="pt-20 flex-grow">
			<slot />
		</main>

		<footer class="bg-[#010413] border-t border-white/5 py-20 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-blue-900/50 to-transparent"></div>

			<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-12 text-center md:text-left">
				<div class="xl:col-span-1">
					<a href="/" class="text-xl font-black tracking-tighter text-white mb-6 block">MADECEM</a>
					<p class="text-slate-300 max-w-sm mx-auto md:mx-0 leading-relaxed text-sm mb-6">
						Ingeniería operativa para empresas que necesitan automatizar mejor, integrar sistemas con sentido y construir una base más sólida para crecer.
					</p>
                    <p class="text-xs uppercase tracking-[0.2em] text-blue-400 font-bold">
                        Automatización · Software · Innovación
                    </p>
				</div>
				
				<div>
					<h3 class="text-white font-bold mb-6 text-sm uppercase tracking-widest">Navegación</h3>
					<ul class="text-slate-300 space-y-3 text-sm">
						<li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
						<li><a href="/empresa" class="hover:text-white transition-colors">Empresa</a></li>
						<li><a href="/servicios" class="hover:text-white transition-colors">Servicios</a></li>
						<li><a href="/como-trabajamos" class="hover:text-white transition-colors">Cómo trabajamos</a></li>
                        <li><a href="/software-e-innovacion" class="hover:text-white transition-colors">Software e innovación</a></li>
					</ul>
				</div>
				
				<div>
					<h3 class="text-white font-bold mb-6 text-sm uppercase tracking-widest">Capacidades</h3>
					<ul class="text-slate-300 space-y-3 text-sm">
                        <li><a href="/servicios" class="hover:text-white transition-colors">Automatización de atención</a></li>
                        <li><a href="/servicios" class="hover:text-white transition-colors">Agenda, reservas y pedidos</a></li>
                        <li><a href="/software-e-innovacion" class="hover:text-white transition-colors">Integración de sistemas</a></li>
                        <li><a href="/software-e-innovacion" class="hover:text-white transition-colors">Software específico</a></li>
                        <li><a href="/software-e-innovacion" class="hover:text-white transition-colors">Innovación operativa</a></li>
					</ul>
				</div>

                <div>
					<h3 class="text-white font-bold mb-6 text-sm uppercase tracking-widest">Contacto y legal</h3>
					<ul class="text-slate-300 space-y-3 text-sm">
                        <li><a href="/#contacto" class="hover:text-white transition-colors">Solicitar diagnóstico</a></li>
                        <li><a href="/legal#aviso" class="hover:text-white transition-colors">Aviso Legal</a></li>
                        <li><a href="/legal#privacidad" class="hover:text-white transition-colors">Privacidad</a></li>
                        <li><a href="/legal#cookies" class="hover:text-white transition-colors">Cookies</a></li>
					</ul>
				</div>
			</div>
            
            <div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row gap-4 md:items-center md:justify-between text-center md:text-left">
                <p class="text-xs text-slate-300">&copy; {currentYear} MADECEM S.L. Todos los derechos reservados.</p>
                <p class="text-xs text-slate-500">Ingeniería operativa para empresas.</p>
            </div>
		</footer>

		<script>
			const btn = document.getElementById('mobile-menu-button');
			const menu = document.getElementById('mobile-menu');
			const links = document.querySelectorAll('.mobile-link');

			btn?.addEventListener('click', () => {
				menu?.classList.toggle('hidden');
			});

			links.forEach(link => {
				link.addEventListener('click', () => {
					menu?.classList.add('hidden');
				});
			});
		</script>

	</body>
</html>