---
import Layout from '../layouts/Layout.astro';
import LeadForm from '../components/LeadForm.astro';
---

<Layout
  title="MADECEM | Ingeniería operativa para empresas: automatización, software e innovación"
  description="Automatización, software específico e innovación operativa para empresas, pymes y negocios en Alcalá de Henares, Guadalajara, Cabanillas del Campo, Madrid y Corredor del Henares."
>
  <section class="relative overflow-hidden pt-20 pb-24 md:pt-28 md:pb-32">
    <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center opacity-45 [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.20),transparent_28%),radial-gradient(circle_at_bottom_left,rgba(16,185,129,0.14),transparent_28%)]"></div>
    <div class="absolute inset-y-0 right-0 w-[42vw] bg-[linear-gradient(180deg,rgba(37,99,235,0.12),rgba(14,165,233,0.04)_35%,transparent_80%)] blur-2xl"></div>

    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1.02fr_0.98fr] gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-slate-200 font-bold text-sm mb-8 backdrop-blur-sm">
            Ingeniería operativa para empresas: automatización, software e innovación
          </div>

          <h1 class="text-4xl md:text-7xl font-black tracking-tighter leading-[1.02] mb-8 max-w-5xl">
            Convertimos procesos manuales en <span class="text-blue-500">sistemas que venden, organizan y escalan mejor.</span>
          </h1>

          <p class="text-lg md:text-2xl text-slate-300 leading-relaxed max-w-4xl mb-10">
            En MADECEM diseñamos automatización, software específico e innovación aplicada para negocios, pymes y empresas que quieren operar con menos fricción, menos improvisación y más control.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="#contacto" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-4 rounded-full font-bold text-lg transition-all hover:scale-[1.02] text-center shadow-lg shadow-blue-600/20">
              Solicitar diagnóstico
            </a>
            <a href="/servicios" class="bg-white/5 hover:bg-white/10 border border-white/10 text-white px-8 py-4 rounded-full font-bold text-lg transition-colors text-center backdrop-blur-sm">
              Ver soluciones
            </a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm hover:bg-white/10 transition-colors">
              <div class="text-white font-bold mb-1">Negocio local y pyme</div>
              <p class="text-slate-300">Atención, agenda, pedidos y operaciones más limpias.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm hover:bg-white/10 transition-colors">
              <div class="text-white font-bold mb-1">Software e integración</div>
              <p class="text-slate-300">Herramientas conectadas a tu proceso real de trabajo.</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm hover:bg-white/10 transition-colors">
              <div class="text-white font-bold mb-1">Innovación e industria 4.0</div>
              <p class="text-slate-300">Digitalización operativa e iniciativas de mayor complejidad técnica.</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-6 bg-blue-500/15 blur-[100px] rounded-full"></div>
          <div class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-blue-500/10 via-transparent to-emerald-500/5 blur-xl scale-105"></div>

          <div class="relative rounded-[2rem] border border-white/10 bg-slate-950/90 shadow-2xl overflow-hidden before:absolute before:inset-0 before:bg-[linear-gradient(135deg,rgba(255,255,255,0.05),transparent_38%)] before:pointer-events-none min-h-[560px]">
            <img
              src="/images/madecem-home-hero.png"
              alt="Visual abstracto de sistemas conectados y flujos operativos"
              class="absolute inset-0 w-full h-full object-cover opacity-70"
            />
            <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(2,6,23,0.82),rgba(2,6,23,0.35)_48%,rgba(2,6,23,0.72))]"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.22),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(16,185,129,0.18),transparent_22%)]"></div>

            <div class="relative h-full p-6 md:p-8 flex flex-col justify-between min-h-[560px]">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-xs uppercase tracking-[0.25em] text-blue-300 font-bold">Arquitectura visual</p>
                  <h2 class="text-2xl font-black mt-2">Automatización, integración y sistema</h2>
                </div>
                <span class="text-xs px-3 py-1 rounded-full bg-white/10 text-slate-200 border border-white/10 backdrop-blur-sm">Base MADECEM</span>
              </div>

              <div class="max-w-lg ml-auto">
                <div class="rounded-3xl border border-white/10 bg-slate-950/55 backdrop-blur-md p-6 shadow-2xl">
                  <p class="text-sm font-bold uppercase tracking-[0.22em] text-blue-300 mb-4">Qué proyecta esta imagen</p>
                  <div class="space-y-4 text-sm text-slate-200">
                    <div class="flex items-start gap-3">
                      <span class="mt-1 w-2 h-2 rounded-full bg-blue-400"></span>
                      <p>Sistemas conectados con lógica operativa y estructura real.</p>
                    </div>
                    <div class="flex items-start gap-3">
                      <span class="mt-1 w-2 h-2 rounded-full bg-emerald-400"></span>
                      <p>Software, automatización e integración sin estética de humo ni stock genérico.</p>
                    </div>
                    <div class="flex items-start gap-3">
                      <span class="mt-1 w-2 h-2 rounded-full bg-cyan-400"></span>
                      <p>Una dirección visual más técnica, más sobria y más propia para la marca.</p>
                    </div>
                  </div>

                  <div class="mt-6 pt-5 border-t border-white/10 flex items-center justify-between gap-4">
                    <p class="text-xs text-slate-400">Podemos seguir refinando esta línea visual en otras secciones.</p>
                    <a href="/software-e-innovacion" class="text-sm font-bold text-blue-300 hover:text-blue-200 transition-colors whitespace-nowrap">Ver capacidad técnica →</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 border-t border-white/5 bg-[#010413] relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.08),transparent_26%),radial-gradient(circle_at_bottom_right,rgba(14,165,233,0.05),transparent_24%)]"></div>

    <div class="max-w-7xl mx-auto px-6 relative">
      <div class="max-w-3xl mb-14">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Problemas reales</p>
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter mb-6">No hace falta más ruido tecnológico. Hace falta que el negocio funcione mejor.</h2>
        <p class="text-slate-300 text-lg">Automatizar bien no consiste en poner una herramienta de moda, sino en resolver puntos de fricción reales: conversaciones sin seguimiento, pedidos mal recogidos, tareas repetitivas, sistemas desconectados y procesos imposibles de escalar.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm hover:bg-white/10 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-bold text-white mb-3">Mensajes y leads sin control</h3>
          <p class="text-slate-300 text-sm">Consultas que llegan, se enfrían o se responden tarde porque no hay sistema detrás.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm hover:bg-white/10 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-bold text-white mb-3">Agenda y operativa desordenadas</h3>
          <p class="text-slate-300 text-sm">Reservas, confirmaciones y cambios manuales que consumen tiempo y generan errores.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm hover:bg-white/10 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-bold text-white mb-3">Herramientas que no se hablan</h3>
          <p class="text-slate-300 text-sm">CRM, formularios, hojas, chats y sistemas desconectados que obligan a duplicar trabajo.</p>
        </div>
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm hover:bg-white/10 hover:-translate-y-1 transition-all duration-300">
          <h3 class="font-bold text-white mb-3">Procesos sin trazabilidad</h3>
          <p class="text-slate-300 text-sm">Cuando todo depende de personas concretas, el crecimiento se vuelve frágil y caro.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="soluciones" class="py-24 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Soluciones</p>
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter mb-6">Desde negocio local hasta proyectos de software e innovación industrial</h2>
        <p class="text-slate-300 text-lg">Trabajamos allí donde hace falta ordenar, automatizar o rediseñar procesos para que soporten trabajo real.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/servicios" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-blue-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <h3 class="text-2xl font-black mb-4">Atención automática y captación</h3>
            <p class="text-slate-300 mb-5">WhatsApp, Telegram, web y formularios conectados con lógica de negocio para responder mejor y filtrar oportunidades reales.</p>
            <ul class="space-y-3 text-sm text-slate-200">
              <li>• Primera respuesta y clasificación</li>
              <li>• Seguimiento comercial</li>
              <li>• Derivación a humano cuando toca</li>
            </ul>
          </div>
        </a>

        <a href="/servicios" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-emerald-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <h3 class="text-2xl font-black mb-4">Agenda, reservas y pedidos</h3>
            <p class="text-slate-300 mb-5">Sistemas que recogen datos, confirman, estructuran y reducen la carga operativa del día a día.</p>
            <ul class="space-y-3 text-sm text-slate-200">
              <li>• Citas y recordatorios</li>
              <li>• Pedidos y formularios</li>
              <li>• Menos errores y menos retrabajo</li>
            </ul>
          </div>
        </a>

        <a href="/software-e-innovacion" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-cyan-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <h3 class="text-2xl font-black mb-4">Software específico e integración</h3>
            <p class="text-slate-300 mb-5">Cuando una herramienta estándar no basta, diseñamos soluciones adaptadas a tu flujo y conectadas con tus sistemas.</p>
            <ul class="space-y-3 text-sm text-slate-200">
              <li>• Software a medida</li>
              <li>• Integración con CRM, ERP y APIs</li>
              <li>• Automatización entre plataformas</li>
            </ul>
          </div>
        </a>

        <a href="/software-e-innovacion" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-purple-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <h3 class="text-2xl font-black mb-4">Innovación e industria 4.0</h3>
            <p class="text-slate-300 mb-5">Impulsamos proyectos de digitalización operativa, automatización industrial e inteligencia aplicada a producción y control.</p>
            <ul class="space-y-3 text-sm text-slate-200">
              <li>• Procesos industriales más inteligentes</li>
              <li>• Monitorización y digitalización</li>
              <li>• Innovación conectada con negocio real</li>
            </ul>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 border-t border-white/5 bg-[#020617] relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.08),transparent_32%)]"></div>

    <div class="max-w-7xl mx-auto px-6 relative">
      <div class="max-w-3xl mb-12">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Arquitectura de la propuesta</p>
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter mb-6">Una web pensada para explicar quiénes somos, qué hacemos y cómo aterrizamos cada proyecto.</h2>
        <p class="text-slate-300 text-lg">Estas tres piezas ayudan a entender mejor la empresa, el proceso y la profundidad técnica detrás de la propuesta.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <a href="/empresa" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-blue-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Empresa</p>
            <h3 class="text-2xl font-black mb-4">Quiénes somos y cómo pensamos</h3>
            <p class="text-slate-300">Conoce qué es MADECEM, cómo pensamos y por qué enfocamos la tecnología desde la operación.</p>
          </div>
        </a>

        <a href="/como-trabajamos" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-emerald-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Cómo trabajamos</p>
            <h3 class="text-2xl font-black mb-4">Método, criterio y proceso</h3>
            <p class="text-slate-300">Diagnóstico, priorización, diseño, implementación y evolución con criterio, no con improvisación.</p>
          </div>
        </a>

        <a href="/software-e-innovacion" class="group rounded-3xl border border-white/10 bg-white/5 p-8 block hover:bg-white/10 hover:border-purple-500/30 transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Software e innovación</p>
            <h3 class="text-2xl font-black mb-4">Capacidad técnica para casos más complejos</h3>
            <p class="text-slate-300">Software específico, integración avanzada, tratamiento documental e innovación aplicada a negocio real.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section id="contacto" class="py-24 bg-gradient-to-b from-[#010413] to-blue-950/20 border-t border-white/5 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.10),transparent_30%)]"></div>

    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-400 mb-4">Siguiente paso</p>
      <h2 class="text-4xl md:text-6xl font-black tracking-tighter mb-8">Si quieres automatizar en serio, primero hay que entender cómo funciona tu negocio.</h2>
      <p class="text-xl text-slate-300 mb-10">Te ayudamos a detectar qué conviene automatizar, qué parte necesita software específico y qué siguiente paso tiene más sentido en tu caso.</p>
      <LeadForm sourcePage="home" formType="diagnostico-home" compact={true} />
    </div>
  </section>
</Layout>
